## 9. AI Prompt Engineering

### The Master Matching Prompt

```typescript
// server/src/prompts/matchFields.ts

export function buildMatchPrompt(
  profile: UserProfile,
  fields: FormField[],
  customAnswers: Record<string, string>
): string {
  return `
You are an expert form-filling assistant. Your job is to match a user's profile data 
to web form fields from a job/internship application.

## USER PROFILE:
${JSON.stringify(profile, null, 2)}

## CUSTOM ANSWERS (User-provided answers to common questions):
${JSON.stringify(customAnswers, null, 2)}

## FORM FIELDS TO FILL:
${JSON.stringify(fields.map(f => ({
  selector: f.selector,
  label: f.label,
  type: f.type,
  options: f.options,
  required: f.required,
  context: f.context,
  placeholder: f.placeholder,
})), null, 2)}

## YOUR TASK:
For each form field, determine the best matching value from the user's profile.

## RULES:
1. Match fields semantically — "Full Name" matches firstName + lastName concatenated.
2. For SELECT fields, you MUST pick from the available options list. Choose the closest match.
3. For RADIO/CHECKBOX fields, match the value to the closest option.
4. For DATE fields, return dates in YYYY-MM-DD format.
5. For open-ended TEXTAREA questions (like "Why do you want to join?"), check customAnswers 
   first. If no custom answer exists, generate a brief, professional response based on 
   the profile and the question context. Keep generated answers under 200 words.
6. If you truly cannot determine a value, mark it as unmatched with a reason.
7. For each match, provide a confidence score from 0.0 to 1.0.

## OUTPUT FORMAT (strict JSON):
{
  "matched": [
    {
      "selector": "<field's CSS selector>",
      "value": "<the value to fill>",
      "type": "<field type>",
      "confidence": <0.0-1.0>,
      "source": "<which profile field was used>"
    }
  ],
  "unmatched": [
    {
      "selector": "<field's CSS selector>",
      "label": "<field label>",
      "type": "<field type>",
      "reason": "<why it couldn't be matched>"
    }
  ]
}

Return ONLY the JSON object, no markdown formatting, no explanation.
`;
}
```

### AI Service Implementation

```typescript
// server/src/services/aiService.ts

import { GoogleGenerativeAI } from '@google/generative-ai';
import { buildMatchPrompt } from '../prompts/matchFields';
import { config } from '../config/env';

const genAI = new GoogleGenerativeAI(config.GEMINI_API_KEY);

export async function matchFieldsWithAI(
  profile: UserProfile,
  fields: FormField[],
  customAnswers: Record<string, string>
): Promise<MatchResult> {
  const model = genAI.getGenerativeModel({ 
    model: 'gemini-1.5-flash',
    generationConfig: {
      temperature: 0.1,        // Low temperature for consistent, factual output
      topP: 0.95,
      maxOutputTokens: 4096,
      responseMimeType: 'application/json',  // Force JSON output
    },
  });

  const prompt = buildMatchPrompt(profile, fields, customAnswers);

  const result = await model.generateContent(prompt);
  const response = result.response;
  const text = response.text();

  try {
    const parsed = JSON.parse(text);
    return {
      matched: parsed.matched || [],
      unmatched: parsed.unmatched || [],
      overallConfidence: calculateOverallConfidence(parsed.matched),
    };
  } catch (parseError) {
    console.error('Failed to parse AI response:', text);
    throw new Error('AI returned invalid JSON response');
  }
}

function calculateOverallConfidence(matched: any[]): number {
  if (!matched.length) return 0;
  const sum = matched.reduce((acc, m) => acc + (m.confidence || 0), 0);
  return Math.round((sum / matched.length) * 100) / 100;
}
```

