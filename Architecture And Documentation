### Phase 3: Content Script — DOM Scraping Engine

> [!WARNING]
> This is the most fragile part of the extension. Career portals use wildly different HTML structures. Your scraper must be resilient.

#### Step 3.1 — Field Scraper Implementation

```typescript
// src/content/scraper.ts

import { FormField } from '../shared/types';

export function scrapeFormFields(): FormField[] {
  const fields: FormField[] = [];
  
  // Query all interactive form elements
  const inputs = document.querySelectorAll<HTMLInputElement>(
    'input:not([type="hidden"]):not([type="submit"]):not([type="button"])'
  );
  const textareas = document.querySelectorAll<HTMLTextAreaElement>('textarea');
  const selects = document.querySelectorAll<HTMLSelectElement>('select');

  inputs.forEach((input) => {
    const field = extractFieldInfo(input);
    if (field) fields.push(field);
  });

  textareas.forEach((textarea) => {
    const field = extractFieldInfo(textarea);
    if (field) fields.push(field);
  });

  selects.forEach((select) => {
    const field = extractFieldInfo(select);
    if (field) {
      field.type = 'select';
      field.options = Array.from(select.options).map(o => o.text.trim()).filter(Boolean);
      fields.push(field);
    }
  });

  return fields;
}

function extractFieldInfo(
  element: HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement
): FormField | null {
  const label = getLabel(element);
  if (!label) return null;  // Skip unlabeled fields

  return {
    selector: generateUniqueSelector(element),
    label,
    type: element instanceof HTMLSelectElement 
      ? 'select' 
      : (element as HTMLInputElement).type as FormField['type'] || 'text',
    currentValue: element.value,
    required: element.required || element.getAttribute('aria-required') === 'true',
    placeholder: element.placeholder || undefined,
    context: getFieldContext(element),
  };
}

function getLabel(element: HTMLElement): string {
  // Strategy 1: Associated <label> element
  const id = element.id;
  if (id) {
    const label = document.querySelector(`label[for="${id}"]`);
    if (label?.textContent) return label.textContent.trim();
  }

  // Strategy 2: aria-label
  const ariaLabel = element.getAttribute('aria-label');
  if (ariaLabel) return ariaLabel.trim();

  // Strategy 3: aria-labelledby
  const labelledBy = element.getAttribute('aria-labelledby');
  if (labelledBy) {
    const refEl = document.getElementById(labelledBy);
    if (refEl?.textContent) return refEl.textContent.trim();
  }

  // Strategy 4: Wrapping <label>
  const parentLabel = element.closest('label');
  if (parentLabel?.textContent) {
    return parentLabel.textContent.replace(element.textContent || '', '').trim();
  }

  // Strategy 5: Placeholder text
  if ((element as HTMLInputElement).placeholder) {
    return (element as HTMLInputElement).placeholder.trim();
  }

  // Strategy 6: Name attribute (fallback)
  const name = element.getAttribute('name');
  if (name) return name.replace(/[_\-]/g, ' ').trim();

  // Strategy 7: Previous sibling text
  const prev = element.previousElementSibling;
  if (prev?.textContent && prev.tagName !== 'INPUT') {
    return prev.textContent.trim();
  }

  return '';
}

function getFieldContext(element: HTMLElement): string {
  // Get the nearest section heading or fieldset legend
  const fieldset = element.closest('fieldset');
  const legend = fieldset?.querySelector('legend');
  
  const section = element.closest('section, [role="group"], .form-section');
  const heading = section?.querySelector('h1, h2, h3, h4, h5, h6');

  const parts: string[] = [];
  if (legend?.textContent) parts.push(`Section: ${legend.textContent.trim()}`);
  if (heading?.textContent) parts.push(`Heading: ${heading.textContent.trim()}`);

  return parts.join(' | ');
}

function generateUniqueSelector(element: HTMLElement): string {
  // Priority: id > name > data-testid > computed path
  if (element.id) return `#${CSS.escape(element.id)}`;
  
  const name = element.getAttribute('name');
  const tag = element.tagName.toLowerCase();
  if (name) return `${tag}[name="${CSS.escape(name)}"]`;

  const testId = element.getAttribute('data-testid');
  if (testId) return `[data-testid="${CSS.escape(testId)}"]`;

  // Fallback: build a path-based selector
  return buildPathSelector(element);
}

function buildPathSelector(element: HTMLElement): string {
  const path: string[] = [];
  let current: HTMLElement | null = element;

  while (current && current !== document.body) {
    let selector = current.tagName.toLowerCase();
    if (current.id) {
      selector = `#${CSS.escape(current.id)}`;
      path.unshift(selector);
      break;
    }
    const parent = current.parentElement;
    if (parent) {
      const siblings = Array.from(parent.children).filter(
        c => c.tagName === current!.tagName
      );
      if (siblings.length > 1) {
        const index = siblings.indexOf(current) + 1;
        selector += `:nth-of-type(${index})`;
      }
    }
    path.unshift(selector);
    current = current.parentElement;
  }

  return path.join(' > ');
}
```

#### Step 3.2 — Form Filler Implementation

```typescript
// src/content/filler.ts

import { FieldMapping } from '../shared/types';

export function fillFields(mappings: FieldMapping[]): FillResult[] {
  const results: FillResult[] = [];

  for (const mapping of mappings) {
    try {
      const element = document.querySelector(mapping.selector);
      if (!element) {
        results.push({ selector: mapping.selector, success: false, error: 'Element not found' });
        continue;
      }

      fillSingleField(element as HTMLElement, mapping);
      results.push({ selector: mapping.selector, success: true });
    } catch (error) {
      results.push({ 
        selector: mapping.selector, 
        success: false, 
        error: (error as Error).message 
      });
    }
  }

  return results;
}

function fillSingleField(element: HTMLElement, mapping: FieldMapping): void {
  const { value, type } = mapping;

  switch (type) {
    case 'select':
      fillSelect(element as HTMLSelectElement, value);
      break;
    case 'radio':
      fillRadio(element as HTMLInputElement, value);
      break;
    case 'checkbox':
      fillCheckbox(element as HTMLInputElement, value);
      break;
    case 'date':
      fillDate(element as HTMLInputElement, value);
      break;
    case 'file':
      // Cannot programmatically set file inputs for security reasons
      // Highlight the field and notify the user
      highlightField(element, 'Please manually upload your file');
      break;
    default:
      fillTextInput(element as HTMLInputElement | HTMLTextAreaElement, value);
  }
}

function fillTextInput(
  element: HTMLInputElement | HTMLTextAreaElement, 
  value: string
): void {
  // Use native input value setter to bypass React/Angular's synthetic events
  const nativeInputValueSetter = Object.getOwnPropertyDescriptor(
    window.HTMLInputElement.prototype, 'value'
  )?.set;
  
  const nativeTextAreaValueSetter = Object.getOwnPropertyDescriptor(
    window.HTMLTextAreaElement.prototype, 'value'
  )?.set;

  const setter = element instanceof HTMLTextAreaElement 
    ? nativeTextAreaValueSetter 
    : nativeInputValueSetter;

  if (setter) {
    setter.call(element, value);
  } else {
    element.value = value;
  }

  // Trigger all possible events that frameworks might listen to
  triggerEvents(element);
}

function fillSelect(element: HTMLSelectElement, value: string): void {
  const options = Array.from(element.options);
  
  // Try exact match first
  let match = options.find(o => 
    o.value.toLowerCase() === value.toLowerCase() || 
    o.text.toLowerCase() === value.toLowerCase()
  );

  // Try partial/fuzzy match
  if (!match) {
    match = options.find(o => 
      o.text.toLowerCase().includes(value.toLowerCase()) ||
      value.toLowerCase().includes(o.text.toLowerCase())
    );
  }

  if (match) {
    element.value = match.value;
    triggerEvents(element);
  }
}

function fillRadio(element: HTMLInputElement, value: string): void {
  const name = element.name;
  const radios = document.querySelectorAll<HTMLInputElement>(
    `input[type="radio"][name="${name}"]`
  );
  
  for (const radio of radios) {
    const label = getRadioLabel(radio);
    if (label.toLowerCase().includes(value.toLowerCase()) ||
        radio.value.toLowerCase() === value.toLowerCase()) {
      radio.checked = true;
      triggerEvents(radio);
      break;
    }
  }
}

function fillCheckbox(element: HTMLInputElement, value: string): void {
  const shouldCheck = ['true', 'yes', '1', 'on'].includes(value.toLowerCase());
  if (element.checked !== shouldCheck) {
    element.click();
  }
}

function fillDate(element: HTMLInputElement, value: string): void {
  // Attempt to parse and format the date to match the input's expected format
  const date = new Date(value);
  if (!isNaN(date.getTime())) {
    const formatted = date.toISOString().split('T')[0]; // YYYY-MM-DD
    element.value = formatted;
    triggerEvents(element);
  }
}

function triggerEvents(element: HTMLElement): void {
  // Dispatch events in the correct order that frameworks expect
  element.dispatchEvent(new Event('focus', { bubbles: true }));
  element.dispatchEvent(new Event('input', { bubbles: true }));
  element.dispatchEvent(new Event('change', { bubbles: true }));
  element.dispatchEvent(new Event('blur', { bubbles: true }));
  
  // React-specific: React 16+ uses a different event system
  element.dispatchEvent(new Event('input', { bubbles: true, composed: true }));
}

function getRadioLabel(radio: HTMLInputElement): string {
  const label = document.querySelector(`label[for="${radio.id}"]`);
  if (label) return label.textContent?.trim() || '';
  const parent = radio.closest('label');
  return parent?.textContent?.trim() || radio.value;
}

function highlightField(element: HTMLElement, message: string): void {
  element.style.outline = '3px solid #F59E0B';
  element.style.outlineOffset = '2px';
  element.title = message;
}

interface FillResult {
  selector: string;
  success: boolean;
  error?: string;
}
```

#### Step 3.3 — Dynamic Form Detection

```typescript
// src/content/detector.ts

export function observeFormChanges(callback: () => void): MutationObserver {
  const observer = new MutationObserver((mutations) => {
    const hasNewForms = mutations.some(mutation => {
      return Array.from(mutation.addedNodes).some(node => {
        if (node instanceof HTMLElement) {
          return node.querySelector('form, input, select, textarea') !== null ||
                 node.matches('form, input, select, textarea');
        }
        return false;
      });
    });

    if (hasNewForms) {
      // Debounce: wait for the DOM to settle
      setTimeout(callback, 500);
    }
  });

  observer.observe(document.body, {
    childList: true,
    subtree: true,
  });

  return observer;
}
