### Phase 4: Background Script — The Central Hub

```typescript
// src/background/index.ts

import { MessageType, Message } from '../shared/messages';
import { getProfile } from './storageManager';
import { callMatchFieldsAPI } from './apiClient';

// Listen for messages from popup and content scripts
chrome.runtime.onMessage.addListener((message: Message, sender, sendResponse) => {
  handleMessage(message, sender).then(sendResponse);
  return true; // Keep the channel open for async response
});

async function handleMessage(message: Message, sender: chrome.runtime.MessageSender) {
  switch (message.type) {
    case MessageType.START_AUTOFILL: {
      // Step 1: Tell the content script to scrape form fields
      const tab = await getActiveTab();
      if (!tab?.id) return { success: false, error: 'No active tab' };

      const fields = await chrome.tabs.sendMessage(tab.id, {
        type: MessageType.SCRAPE_FIELDS,
      });

      if (!fields?.length) {
        return { success: false, error: 'No form fields detected on this page' };
      }

      // Step 2: Get user profile
      const profile = await getProfile();
      if (!profile) {
        return { success: false, error: 'No profile found. Please set up your profile first.' };
      }

      // Step 3: Call the backend for AI matching
      const customAnswers = await getCustomAnswers();
      const matchResult = await callMatchFieldsAPI(profile, fields, customAnswers);

      // Step 4: Send matched fields back to content script for filling
      const fillResult = await chrome.tabs.sendMessage(tab.id, {
        type: MessageType.FILL_FIELDS,
        data: matchResult.matched,
      });

      return {
        success: true,
        filled: fillResult,
        unmatched: matchResult.unmatched,
        totalFields: fields.length,
      };
    }

    case MessageType.SAVE_CUSTOM_ANSWER: {
      const { label, answer } = message.data;
      await saveCustomAnswer(label, answer);
      return { success: true };
    }

    default:
      return { success: false, error: 'Unknown message type' };
  }
}

async function getActiveTab(): Promise<chrome.tabs.Tab | undefined> {
  const [tab] = await chrome.tabs.query({ active: true, currentWindow: true });
  return tab;
}

async function getCustomAnswers(): Promise<Record<string, string>> {
  const result = await chrome.storage.local.get('customAnswers');
  return result.customAnswers || {};
}
